install.packages(c("tidyverse", "lubridate", "plotly"))
cat("Date range:", as.character(min(main_df$date)),
"→", as.character(max(main_df$date)), "\n")
source("~/Desktop/Whoop_Scrolly/data_prep.R")
#| label: setup
#| include: false   # "false" = this chunk runs but nothing shows in the doc
library(tidyverse)
library(plotly)
library(lubridate)
# Load the cleaned data from prep_data.R
main_df        <- readRDS("data/main_df.rds")
workouts_clean <- readRDS("data/workouts_clean.rds")
# ── Summary stats used in the narrative text ─────────────────
n_days      <- nrow(main_df)
avg_hrv     <- round(mean(main_df$hrv, na.rm = TRUE))
avg_recovery<- round(mean(main_df$recovery, na.rm = TRUE))
n_workouts  <- nrow(workouts_clean)
date_start  <- format(min(main_df$date), "%B %Y")
date_end    <- format(max(main_df$date), "%B %Y")
pct_green   <- round(mean(main_df$recovery_zone == "Green", na.rm=TRUE)*100)
# ── Color palette (WHOOP-inspired traffic light) ─────────────
zone_colors <- c("Red" = "#FF6B6B", "Yellow" = "#FFD166", "Green" = "#06D6A0")
# For charts that use a SINGLE trace (needed for dropdown/switching),
# we map each row's recovery zone to a hex color manually.
# This is a workaround because plotly's color= grouping creates
# multiple traces, which breaks x/y variable switching.
marker_cols <- zone_colors[as.character(main_df$recovery_zone)]
## From `r date_start` to `r date_end` — `r n_days` days. `r n_workouts` workouts. One story.
> WHOOP shows you a number every morning. But it rarely tells you *why* that number is what it is, or what it means for what you're about to do. This page changes that.
